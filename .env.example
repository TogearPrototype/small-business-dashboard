# Neon Postgres connection string (pooled).
# Get it from the Neon console → your project → Connection Details.
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Set to "true" to read/write through Neon instead of the in-memory demo store.
# Leave unset/false to run the app on seeded demo data with no database.
USE_DATABASE="false"

# --- Auth (Neon Auth / Stack Auth) ---
# Provision via the Neon console → Auth tab, then paste the keys here.
NEXT_PUBLIC_STACK_PROJECT_ID=""
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=""
STACK_SECRET_SERVER_KEY=""
