# Neon Postgres connection string (pooled).
# On Vercel this is injected automatically by the Neon integration — you do NOT
# need to set it there. For local dev, copy the pooled string from the Neon
# console → Connection Details.
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# The app uses Neon automatically whenever DATABASE_URL is set. Only set this to
# "false" to FORCE the in-memory demo store even when a DATABASE_URL exists
# (e.g. local dev without a live DB). Leave it unset in production.
# USE_DATABASE="false"

# --- Auth (Neon Auth / Stack Auth) ---
# Provision via the Neon console → Auth tab, then paste the keys here.
NEXT_PUBLIC_STACK_PROJECT_ID=""
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=""
STACK_SECRET_SERVER_KEY=""
